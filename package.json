{
  "name": "tc-vrm-viewer-web-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "build:mistlib": "bash scripts/build-mistlib.sh",
    "pretest": "node -e \"require('node:fs').rmSync('dist-test',{recursive:true,force:true})\"",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/tests/*.test.js"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.4.2",
    "lucide-preact": "^1.14.0",
    "preact": "^10.29.1",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^24.12.3",
    "@types/three": "^0.180.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  }
}
